# Arc Testnet RPC (fallback otomatis ke public RPC kalau kosong)
RPC_URL=https://arc-testnet.g.alchemy.com/v2/apikeymu
CHAIN_ID=5042002
EXPLORER=https://testnet.arcscan.app

# Daftar private key, pisahkan dengan koma (TANPA 0x juga boleh)
# Contoh: PRIVATE_KEYS=0xabc...,0xdef...
PRIVATE_KEYS=

# Atau simpan di file wallets.txt (satu PK per baris). Kalau diisi, override PRIVATE_KEYS.
WALLETS_FILE=wallets.txt

# Jumlah transaksi per wallet per run
TX_PER_WALLET=1

# Delay antar tx per wallet (ms) - range acak [min,max]
# Semakin kecil = lebih cepat, tapi resiko rate-limit RPC naik
DELAY_MIN_MS=100
DELAY_MAX_MS=1500

# Delay antar wallet (ms)
WALLET_DELAY_MIN_MS=1500
WALLET_DELAY_MAX_MS=5000

# Jalankan wallet secara paralel? (true/false). false = sequential, aman untuk nonce
PARALLEL_WALLETS=false

# Task yang diaktifkan (comma separated): selfTransferUsdc, selfTransferEurc, randomTransferUsdc, deployErc20, deployNft, mintNft
ENABLED_TASKS=selfTransferUsdc,selfTransferEurc,randomTransferUsdc,deployErc20,deployNft

# Jumlah USDC per self-transfer (dalam unit USDC, bukan wei). Desimal OK.
SELF_TX_AMOUNT_USDC=0.1
SELF_TX_AMOUNT_EURC=0.1

# Loop mode: jalankan terus-menerus dengan jeda antar siklus
LOOP=false
LOOP_DELAY_MIN_MS=300000
LOOP_DELAY_MAX_MS=900000

# === CCTP BRIDGE (Sepolia -> Arc) ===
# RPC Sepolia untuk bridging (public default oke)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Jumlah USDC yang di-bridge per wallet
BRIDGE_AMOUNT_USDC=1
# Alamat tujuan di Arc (kosongkan = bridge ke address yang sama / self)
BRIDGE_DEST_ADDRESS=
# Interval polling attestation Circle IRIS (ms). Default 2000 (cepat)
BRIDGE_POLL_MS=2000

# === zkCodex tasks ===
# Jumlah kali call Counter per cycle per wallet (default 3, bisa dinaikkan)
COUNTER_PER_CYCLE=3
